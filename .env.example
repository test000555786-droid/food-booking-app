# Prisma should point at your Supabase Postgres connection string.
DATABASE_URL=

# Existing custom staff auth still requires a server-side JWT secret.
JWT_SECRET=

# App URL used for QR generation and absolute links.
NEXT_PUBLIC_APP_URL=

# Optional realtime configuration already used elsewhere in the app.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
